{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "NexusPay",
    "Audience": "NexusPayUsers",
    "Key": "YOUR_SECRET_KEY_MIN_32_CHARS",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "GrpcServer": {
    "BaseUrl": "https://127.0.0.1:7199"
  },
  "AllowedHosts": "*"
}
